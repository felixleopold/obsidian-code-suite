{
  "name": "obsidian-syntax-highlighting",
  "version": "1.9.0",
  "description": "VS Code-quality syntax highlighting for Obsidian code blocks using Shiki + Gruvbox",
  "main": "dist/main.js",
  "scripts": {
    "build": "node esbuild.config.js production",
    "dev": "node esbuild.config.js",
    "install-plugin": "node esbuild.config.js",
    "vault-install": "bash scripts/install.sh",
    "lint": "eslint src/",
    "release": "bash scripts/release.sh"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/felixleopold/obsidian-syntax-highlighting.git"
  },
  "keywords": [
    "obsidian",
    "syntax-highlighting",
    "shiki",
    "gruvbox"
  ],
  "author": "Felix Leopold",
  "license": "Apache-2.0",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/felixleopold/obsidian-syntax-highlighting/issues"
  },
  "homepage": "https://github.com/felixleopold/obsidian-syntax-highlighting#readme",
  "devDependencies": {
    "@codemirror/language": "^6.12.3",
    "@codemirror/state": "6.5.0",
    "@codemirror/view": "^6.36.5",
    "@eslint/js": "^9.30.1",
    "@eslint/json": "0.14.0",
    "@lezer/highlight": "^1.2.3",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "esbuild": "^0.27.4",
    "eslint": "^9.30.0",
    "eslint-plugin-obsidianmd": "^0.1.9",
    "obsidian": "^1.12.3",
    "typescript": "~5.9.0",
    "typescript-eslint": "^8.57.2"
  },
  "dependencies": {
    "shiki": "^4.0.2"
  }
}
